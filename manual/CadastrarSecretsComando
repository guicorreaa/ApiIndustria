// PRIMEIRO PASSO - CRIAR TUDO O QUE PRECISA NO DOCKER

// TODOS OS DADOS QUE ESTÃO AQUI SÃO APENAS DE EXEMPLO

// Iniciar o docker swarm
docker swarm init

// Criar a rede em overlay
docker network create --driver overlay --attachable api-industria

// criar a pasta dentro do WSL
mkdir -p ./user/secrets

// Criar as secrets (usando WSL do subsistema)
echo -n "postgres" > ./user/secrets/postgres_user.txt
chmod 600 ./user/secrets/postgres_user.txt
docker secret create POSTGRES_USER ./user/secrets/postgres_user.txt
shred -u ./user/secrets/postgres_user.txt

echo -n "postgres123" > ./user/secrets/postgres_password.txt
chmod 600 ./user/secrets/postgres_password.txt
docker secret create POSTGRES_PASSWORD ./user/secrets/postgres_password.txt
shred -u ./user/secrets/postgres_password.txt

echo -n "postgres123" > ./user/secrets/pg_admin_password.txt
chmod 600 ./user/secrets/pg_admin_password.txt
docker secret create PGADMIN_DEFAULT_PASSWORD ./user/secrets/pg_admin_password.txt
shred -u ./user/secrets/pg_admin_password.txt

docker pull postgres:16.10-trixie

docker pull dpage/pgadmin4:9.10.0

// Criar o volume do banco de dados (usando Ubuntu)
docker volume create banco-api-bkp

// Criar serviço do banco de dados (no caso ao criar no pc para desenvolver no docker local, preciso expor aporta --publish published=5432,target=5432 para o spring conseguir acessar,
// porém quando for publicar na vps, não criar com o --publish published=5432,target=5432, pois não é seguro) - (usando Ubuntu)
docker service create --name banco-industria --network api-industria --publish published=5432,target=5432 --secret POSTGRES_USER --secret POSTGRES_PASSWORD --env POSTGRES_USER_FILE=/run/secrets/POSTGRES_USER --env POSTGRES_PASSWORD_FILE=/run/secrets/POSTGRES_PASSWORD --mount type=volume,source=banco-api-bkp,target=/var/lib/postgresql/data postgres:16.10-trixie

// Criar o serviço do pgadmin - (usando Ubuntu)
docker service create --name pgadmin4 --network api-industria -e PGADMIN_DEFAULT_EMAIL=admin@admin.com.br --secret PGADMIN_DEFAULT_PASSWORD -e PGADMIN_DEFAULT_PASSWORD_FILE=/run/secrets/PGADMIN_DEFAULT_PASSWORD -p 5050:80 dpage/pgadmin4:9.10.0
